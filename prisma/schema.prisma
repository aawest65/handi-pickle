generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

enum Role {
  USER
  ADMIN
  SUPER_ADMIN
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          Role      @default(USER)

  accounts Account[]
  sessions Session[]
  player   Player?
}

model Player {
  id                 String   @id @default(cuid())
  userId             String   @unique
  name               String
  gender             String   // MALE | FEMALE
  dateOfBirth        DateTime @db.Date
  city               String?
  state              String?
  selfRatedCategory  String   @default("NOVICE")
  currentRating      Float    @default(3.0)
  gamesPlayed        Int      @default(0)
  createdAt          DateTime @default(now())
  dominantHand       String?  // RIGHT | LEFT | AMBIDEXTROUS
  yearsPlaying       Int?
  preferredFormat    String?  // SINGLES | DOUBLES | BOTH
  duprRating         Float?
  avatarUrl          String?
  onboardingComplete Boolean  @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  team1Player1Games Game[]         @relation("T1P1")
  team1Player2Games Game[]         @relation("T1P2")
  team2Player1Games Game[]         @relation("T2P1")
  team2Player2Games Game[]         @relation("T2P2")
  ratingHistory     RatingHistory[]
}

// gameType: REC | CLUB | TOURNEY_REG | TOURNEY_MEDAL
// format:   SINGLES | DOUBLES
model Game {
  id             String   @id @default(cuid())
  gameType       String
  format         String
  date           DateTime
  maxScore       Int      @default(11)
  team1Score     Int
  team2Score     Int
  createdAt      DateTime @default(now())

  team1Player1Id String
  team1Player2Id String?
  team2Player1Id String
  team2Player2Id String?

  team1Player1  Player  @relation("T1P1", fields: [team1Player1Id], references: [id])
  team1Player2  Player? @relation("T1P2", fields: [team1Player2Id], references: [id])
  team2Player1  Player  @relation("T2P1", fields: [team2Player1Id], references: [id])
  team2Player2  Player? @relation("T2P2", fields: [team2Player2Id], references: [id])

  ratingHistory RatingHistory[]
}

model RatingHistory {
  id             String   @id @default(cuid())
  playerId       String
  gameId         String
  ratingBefore   Float
  ratingAfter    Float
  delta          Float
  winLossFactor  Float
  typeFactor     Float
  genderFactor   Float
  ageFactor      Float
  rateTypeFactor Float
  createdAt      DateTime @default(now())

  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)
  game   Game   @relation(fields: [gameId], references: [id], onDelete: Cascade)
}
