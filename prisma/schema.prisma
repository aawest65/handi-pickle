generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

enum Role {
  USER
  ADMIN
  SUPER_ADMIN
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          Role      @default(USER)

  // Legal consent — stored as timestamps for audit trail
  termsAcceptedAt    DateTime? // ToS + Privacy Policy (required)
  dataShareConsentAt DateTime? // sharing with tournament directors / club admins (required)
  emailConsentAt     DateTime? // marketing/notification emails (optional, CAN-SPAM compliant)

  accounts            Account[]
  sessions            Session[]
  player              Player?
  passwordResetTokens PasswordResetToken[]
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PlayerCategoryRating {
  id           String   @id @default(cuid())
  playerId     String
  format       String   // SINGLES | DOUBLES | MIXED
  gameCategory String   // REC | CLUB | TOURNEY
  rating       Float    @default(3.0)
  gamesPlayed  Int      @default(0)
  wins         Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([playerId, format, gameCategory])
}

model SportsmanshipRating {
  id            String   @id @default(cuid())
  gameId        String
  raterId       String
  ratedPlayerId String
  score         Int      // 1–5
  createdAt     DateTime @default(now())

  game        Game   @relation(fields: [gameId], references: [id], onDelete: Cascade)
  rater       Player @relation("Rater", fields: [raterId], references: [id], onDelete: Cascade)
  ratedPlayer Player @relation("RatedPlayer", fields: [ratedPlayerId], references: [id], onDelete: Cascade)

  @@unique([gameId, raterId, ratedPlayerId])
}

model Club {
  id          String   @id @default(cuid())
  name        String   @unique
  city        String?
  state       String?
  description String?
  createdAt   DateTime @default(now())

  players Player[]
}

model Player {
  id                 String   @id @default(cuid())
  playerNumber       String   @unique
  userId             String   @unique
  name               String
  gender             String   // MALE | FEMALE
  dateOfBirth        DateTime @db.Date
  city               String?
  state              String?
  clubId             String?
  selfRatedCategory  String   @default("NOVICE")
  initialRating      Float    @default(3.0)
  currentRating      Float    @default(3.0)
  gamesPlayed        Int      @default(0)

  // Per-format ratings — seeded from currentRating on migration, diverge from there
  singlesRating      Float    @default(3.0)
  doublesRating      Float    @default(3.0)
  mixedRating        Float    @default(3.0)
  singlesGamesPlayed Int      @default(0)
  doublesGamesPlayed Int      @default(0)
  mixedGamesPlayed   Int      @default(0)
  createdAt          DateTime @default(now())
  dominantHand       String?  // RIGHT | LEFT | AMBIDEXTROUS
  yearsPlaying       Int?
  preferredFormat    String?  // SINGLES | DOUBLES | BOTH
  duprRating         Float?
  avatarUrl          String?
  onboardingComplete Boolean  @default(false)
  showAge            Boolean  @default(true)
  sportsmanshipSum   Float    @default(0)
  sportsmanshipCount Int      @default(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  club Club? @relation(fields: [clubId], references: [id], onDelete: SetNull)

  team1Player1Games    Game[]                @relation("T1P1")
  team1Player2Games    Game[]                @relation("T1P2")
  team2Player1Games    Game[]                @relation("T2P1")
  team2Player2Games    Game[]                @relation("T2P2")
  ratingHistory        RatingHistory[]
  categoryRatings      PlayerCategoryRating[]
  sportsmanshipGiven   SportsmanshipRating[] @relation("Rater")
  sportsmanshipReceived SportsmanshipRating[] @relation("RatedPlayer")
}

// gameType: REC | CLUB | TOURNEY_REG | TOURNEY_MEDAL
// format:   SINGLES | DOUBLES
// isMixed:  true when format=DOUBLES and at least one team has players of different genders
model Game {
  id             String   @id @default(cuid())
  gameType       String
  format         String
  isMixed        Boolean  @default(false)
  date           DateTime
  maxScore       Int      @default(11)
  team1Score     Int
  team2Score     Int
  createdAt      DateTime @default(now())

  team1Player1Id String
  team1Player2Id String?
  team2Player1Id String
  team2Player2Id String?

  team1Player1  Player  @relation("T1P1", fields: [team1Player1Id], references: [id])
  team1Player2  Player? @relation("T1P2", fields: [team1Player2Id], references: [id])
  team2Player1  Player  @relation("T2P1", fields: [team2Player1Id], references: [id])
  team2Player2  Player? @relation("T2P2", fields: [team2Player2Id], references: [id])

  ratingHistory        RatingHistory[]
  sportsmanshipRatings SportsmanshipRating[]
}

model RatingHistory {
  id             String   @id @default(cuid())
  playerId       String
  gameId         String
  ratingBefore   Float
  ratingAfter    Float
  delta          Float
  ratingFormat   String   // SINGLES | DOUBLES | MIXED
  winLossFactor  Float
  typeFactor     Float
  genderFactor   Float
  ageFactor      Float
  rateTypeFactor Float
  createdAt      DateTime @default(now())

  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)
  game   Game   @relation(fields: [gameId], references: [id], onDelete: Cascade)
}
