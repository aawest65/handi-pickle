generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

enum Role {
  USER
  ADMIN
  SUPER_ADMIN
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          Role      @default(USER)

  // Legal consent — stored as timestamps for audit trail
  termsAcceptedAt    DateTime? // ToS + Privacy Policy (required)
  dataShareConsentAt DateTime? // sharing with tournament directors / club admins (required)
  emailConsentAt     DateTime? // marketing/notification emails (optional, CAN-SPAM compliant)

  isClubAdmin          Boolean @default(false)
  isTournamentDirector Boolean @default(false)

  accounts              Account[]
  sessions              Session[]
  player                Player?
  passwordResetTokens   PasswordResetToken[]
  primaryAdminClubs     Club[]               @relation("ClubPrimaryAdmin")
  backupAdminClubs      Club[]               @relation("ClubBackupAdmin")
  createdTournaments    Tournament[]         @relation("TournamentCreatedBy")
  tournamentDirectorFor TournamentDirector[]
  clubRequests          ClubRequest[]
  clubJoinReviews       ClubJoinRequest[]    @relation("ClubJoinReviewer")
  submittedGames        Game[]               @relation("GameSubmittedBy")
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PlayerCategoryRating {
  id           String   @id @default(cuid())
  playerId     String
  format       String   // SINGLES | DOUBLES | MIXED
  gameCategory String   // REC | CLUB | TOURNEY
  clubId       String?  // null for REC/TOURNEY; club-specific for CLUB games
  rating       Float    @default(3.0)
  gamesPlayed  Int      @default(0)
  wins         Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)
  club   Club?  @relation("ClubCategoryRatings", fields: [clubId], references: [id], onDelete: Cascade)

  @@index([playerId, format, gameCategory, clubId])
}

model SportsmanshipRating {
  id            String   @id @default(cuid())
  gameId        String
  raterId       String
  ratedPlayerId String
  score         Int      // 1–5
  createdAt     DateTime @default(now())

  game        Game   @relation(fields: [gameId], references: [id], onDelete: Cascade)
  rater       Player @relation("Rater", fields: [raterId], references: [id], onDelete: Cascade)
  ratedPlayer Player @relation("RatedPlayer", fields: [ratedPlayerId], references: [id], onDelete: Cascade)

  @@unique([gameId, raterId, ratedPlayerId])
}

model Club {
  id             String   @id @default(cuid())
  name           String   @unique
  city           String?
  state          String?
  description    String?
  logoUrl        String?
  isPrivate      Boolean  @default(false)
  status         String   @default("ACTIVE") // ACTIVE
  primaryAdminId String?
  backupAdminId  String?
  createdAt      DateTime @default(now())

  primaryAdmin    User?        @relation("ClubPrimaryAdmin", fields: [primaryAdminId], references: [id], onDelete: SetNull)
  backupAdmin     User?        @relation("ClubBackupAdmin",  fields: [backupAdminId],  references: [id], onDelete: SetNull)
  memberships     PlayerClub[]
  tournaments     Tournament[]
  requests        ClubRequest[]
  joinRequests    ClubJoinRequest[]
  games           Game[]                 @relation("ClubGames")
  categoryRatings PlayerCategoryRating[] @relation("ClubCategoryRatings")
  ratingHistory   RatingHistory[]        @relation("ClubRatingHistory")
}

model PlayerClub {
  playerId  String
  clubId    String
  isPrimary Boolean  @default(false)
  joinedAt  DateTime @default(now())

  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)
  club   Club   @relation(fields: [clubId],   references: [id], onDelete: Cascade)

  @@id([playerId, clubId])
}

// status: PENDING | APPROVED | REJECTED
model ClubRequest {
  id          String   @id @default(cuid())
  name        String
  city        String?
  state       String?
  description String?
  logoUrl     String?
  note        String?
  status      String   @default("PENDING")
  requestedById String
  clubId      String?
  createdAt   DateTime @default(now())
  reviewedAt  DateTime?

  requestedBy User  @relation(fields: [requestedById], references: [id], onDelete: Cascade)
  club        Club? @relation(fields: [clubId], references: [id], onDelete: SetNull)
}

// status: PENDING | APPROVED | REJECTED
model ClubJoinRequest {
  id           String    @id @default(cuid())
  clubId       String
  playerId     String
  status       String    @default("PENDING")
  requestedAt  DateTime  @default(now())
  reviewedAt   DateTime?
  reviewedById String?

  club       Club    @relation(fields: [clubId],       references: [id], onDelete: Cascade)
  player     Player  @relation(fields: [playerId],     references: [id], onDelete: Cascade)
  reviewedBy User?   @relation("ClubJoinReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@unique([clubId, playerId])
}

model Player {
  id                 String   @id @default(cuid())
  playerNumber       String   @unique
  userId             String   @unique
  name               String
  gender             String   // MALE | FEMALE
  dateOfBirth        DateTime @db.Date
  city               String?
  state              String?
  selfRatedCategory  String   @default("NOVICE")
  initialRating      Float    @default(3.0)
  currentRating      Float    @default(3.0)
  gamesPlayed        Int      @default(0)

  // Per-format ratings — seeded from currentRating on migration, diverge from there
  singlesRating      Float    @default(3.0)
  doublesRating      Float    @default(3.0)
  mixedRating        Float    @default(3.0)
  singlesGamesPlayed Int      @default(0)
  doublesGamesPlayed Int      @default(0)
  mixedGamesPlayed   Int      @default(0)
  createdAt          DateTime @default(now())
  dominantHand       String?  // RIGHT | LEFT | AMBIDEXTROUS
  yearsPlaying       Int?
  preferredFormat    String?  // SINGLES | DOUBLES | BOTH
  duprRating         Float?
  avatarUrl          String?
  onboardingComplete Boolean  @default(false)
  showAge            Boolean  @default(true)
  emailDigestOptOut  Boolean  @default(false)
  sportsmanshipSum   Float    @default(0)
  sportsmanshipCount Int      @default(0)

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  memberships PlayerClub[]
  joinRequests ClubJoinRequest[]

  team1Player1Games    Game[]                @relation("T1P1")
  team1Player2Games    Game[]                @relation("T1P2")
  team2Player1Games    Game[]                @relation("T2P1")
  team2Player2Games    Game[]                @relation("T2P2")
  ratingHistory        RatingHistory[]
  categoryRatings        PlayerCategoryRating[]
  sportsmanshipGiven     SportsmanshipRating[]    @relation("Rater")
  sportsmanshipReceived  SportsmanshipRating[]    @relation("RatedPlayer")
  tournamentRegistrations TournamentRegistration[]
}

model Tournament {
  id                   String    @id @default(cuid())
  name                 String
  description          String?
  location             String?
  city                 String?
  state                String?
  startDate            DateTime
  endDate              DateTime
  registrationOpenAt   DateTime?
  registrationCloseAt  DateTime?
  // status:   DRAFT | REGISTRATION | IN_PROGRESS | COMPLETED | CANCELLED
  status               String    @default("DRAFT")
  // format:   SINGLES | DOUBLES | MIXED | ALL
  format               String    @default("ALL")
  // gameType: TOURNEY_REG | TOURNEY_MEDAL | BOTH
  gameType             String    @default("TOURNEY_REG")
  maxParticipants      Int?
  createdById          String
  clubId               String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  createdBy     User                     @relation("TournamentCreatedBy", fields: [createdById], references: [id])
  club          Club?                    @relation(fields: [clubId], references: [id], onDelete: SetNull)
  directors     TournamentDirector[]
  registrations TournamentRegistration[]
  games         Game[]
}

model TournamentDirector {
  tournamentId String
  userId       String
  isPrimary    Boolean @default(false)

  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId],       references: [id], onDelete: Cascade)

  @@id([tournamentId, userId])
}

model TournamentRegistration {
  id           String    @id @default(cuid())
  tournamentId String
  playerId     String
  // status: CONFIRMED | WAITLISTED | WITHDRAWN
  status       String    @default("CONFIRMED")
  registeredAt DateTime  @default(now())
  confirmedAt  DateTime? @default(now())
  seed         Int?

  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  player     Player     @relation(fields: [playerId],     references: [id], onDelete: Cascade)

  @@unique([tournamentId, playerId])
}

// gameType: REC | CLUB | TOURNEY_REG | TOURNEY_MEDAL
// format:   SINGLES | DOUBLES
// isMixed:  true when format=DOUBLES and at least one team has players of different genders
// clubId:   set when gameType=CLUB; identifies which club the game counts toward
model Game {
  id                String   @id @default(cuid())
  gameType          String
  format            String
  isMixed           Boolean  @default(false)
  date              DateTime
  maxScore          Int      @default(11)
  team1Score        Int
  team2Score        Int
  // PENDING | APPROVED | DISPUTED | FLAGGED
  status            String   @default("PENDING")
  submittedByUserId String?
  createdAt         DateTime @default(now())

  tournamentId   String?
  clubId         String?
  team1Player1Id String
  team1Player2Id String?
  team2Player1Id String
  team2Player2Id String?

  team1Player1  Player      @relation("T1P1", fields: [team1Player1Id], references: [id])
  team1Player2  Player?     @relation("T1P2", fields: [team1Player2Id], references: [id])
  team2Player1  Player      @relation("T2P1", fields: [team2Player1Id], references: [id])
  team2Player2  Player?     @relation("T2P2", fields: [team2Player2Id], references: [id])
  tournament    Tournament? @relation(fields: [tournamentId], references: [id], onDelete: SetNull)
  club          Club?       @relation("ClubGames", fields: [clubId], references: [id], onDelete: SetNull)
  submittedBy   User?       @relation("GameSubmittedBy", fields: [submittedByUserId], references: [id], onDelete: SetNull)

  ratingHistory        RatingHistory[]
  sportsmanshipRatings SportsmanshipRating[]
}

model RatingHistory {
  id             String   @id @default(cuid())
  playerId       String
  gameId         String
  clubId         String?  // set when the game was club play
  ratingBefore   Float
  ratingAfter    Float
  delta          Float
  ratingFormat   String   // SINGLES | DOUBLES | MIXED
  winLossFactor  Float
  typeFactor     Float
  genderFactor   Float
  ageFactor      Float
  rateTypeFactor Float
  createdAt      DateTime @default(now())

  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)
  game   Game   @relation(fields: [gameId], references: [id], onDelete: Cascade)
  club   Club?  @relation("ClubRatingHistory", fields: [clubId], references: [id], onDelete: SetNull)
}
